rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isNotBanned() {
      return isAuth() && !get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned;
    }
    // A client may change only the listed field names on update.
    // Defensive so no user can escalate role/ban flags via the client.
    function changedOnly(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }

    // ── Users ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId)
        && request.resource.data.role in ['user', 'business']  // admins created server-side
        && request.resource.data.isBanned == false;
      // Users may edit their own profile but not role/ban/verified flags.
      // Admins may touch anything.
      allow update: if isAdmin()
        || (isOwner(userId) && changedOnly([
              'name','phone','photoUrl','bio','airline','airport','position',
              'city','state','hobbies','passportStamps','travelHistory',
              'followerCount','followingCount','postCount',
              'lastSeen','fcmToken','matchType','matchPreferences',
              'notificationPrefs','privacySettings'
            ]));
      allow delete: if isAdmin();

      match /following/{followedId} {
        allow read: if isAuth();
        allow write: if isOwner(userId);
      }
      match /followers/{followerId} {
        allow read: if isAuth();
        allow write: if isAuth(); // when someone follows, they write to target's followers
      }
      match /blocked/{blockedId} {
        allow read, write: if isOwner(userId);
      }
      match /savedPosts/{postId} {
        // Only the user may see or modify their own bookmarks.
        allow read, write: if isOwner(userId);
      }
      match /trips/{tripId} {
        allow read: if isAuth();
        allow write: if isOwner(userId);
      }
    }

    // ── Posts ──────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isAuth();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.authorId == request.auth.uid;
      // Post author may edit own fields; any authed user may increment
      // reportCount / set isReported (reporting flow).
      allow update: if isOwner(resource.data.authorId) || isAdmin()
        || (isAuth() && changedOnly(['reportCount','isReported','likeCount','commentCount']));
      allow delete: if isOwner(resource.data.authorId) || isAdmin();

      match /likes/{userId} {
        allow read: if isAuth();
        allow write: if isOwner(userId);
      }
      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth() && isNotBanned()
          && request.resource.data.authorId == request.auth.uid;
        allow delete: if isOwner(resource.data.authorId) || isAdmin();
      }
    }

    // ── Chats ──────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth()
        && request.auth.uid in request.resource.data.participants;
      // Participants may update lastMessage / unreadCount / typing metadata
      // but not change the participants list.
      allow update: if isAuth()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && isNotBanned()
          && request.resource.data.senderId == request.auth.uid;
        // Tightened: sender may edit own message content OR a participant may add
        // themselves to readBy. No one may forge senderId.
        allow update: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == resource.data.senderId
          && (isOwner(resource.data.senderId) || changedOnly(['readBy']));
        allow delete: if isOwner(resource.data.senderId) || isAdmin();
      }
      match /typing/{userId} {
        allow read, write: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.auth.uid == userId;
      }
    }

    // ── Events ─────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isAuth();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.createdBy == request.auth.uid;
      // Creator may edit own fields; any authed user may bump rsvpCount
      // via the RSVP flow. Admin may approve/feature.
      allow update: if isOwner(resource.data.createdBy) || isAdmin()
        || (isAuth() && changedOnly(['rsvpCount','rsvpList']));
      allow delete: if isOwner(resource.data.createdBy) || isAdmin();

      match /rsvps/{userId} {
        allow read: if isAuth();
        allow write: if isOwner(userId);
      }
    }

    // ── Groups ─────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isAuth();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.createdBy == request.auth.uid;
      // Admins of the group may update most fields. Joining/leaving mutates
      // members + memberCount \u2014 allow those two fields for any authed user.
      allow update: if isAdmin()
        || (isAuth() && request.auth.uid in resource.data.admins)
        || (isAuth() && changedOnly(['members','memberCount']));
      allow delete: if isOwner(resource.data.createdBy) || isAdmin();
    }

    // ── Matches ────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if isAuth()
        && (request.auth.uid == resource.data.userA
            || request.auth.uid == resource.data.userB);
      allow create: if isAuth()
        && request.auth.uid == request.resource.data.userA;
      // Only the two participants may update \u2014 and only the status/matchedAt
      // fields (e.g. to transition 'pending' -> 'matched' / 'passed').
      allow update: if isAuth()
        && (request.auth.uid == resource.data.userA
            || request.auth.uid == resource.data.userB)
        && changedOnly(['status','matchedAt','chatId']);
      allow delete: if isOwner(resource.data.userA) || isAdmin();
    }

    // ── Notifications ──────────────────────────────────────
    match /notifications/{notificationId} {
      // Recipient may read, mark-read, delete their own.
      allow read: if isOwner(resource.data.userId);
      // Mark-read only \u2014 can't forge content.
      allow update: if isOwner(resource.data.userId)
        && changedOnly(['isRead']);
      allow delete: if isOwner(resource.data.userId);
      // Creation: admins (broadcast) + authed peers writing on specific
      // user-triggered actions like match, RSVP, etc. Restrict to admin
      // unless the caller is writing a notification TO themselves.
      allow create: if isAdmin()
        || (isAuth() && request.resource.data.userId == request.auth.uid);
    }

    // ── SafeChecks ────────────────────────────────────────
    match /safeChecks/{checkId} {
      allow read: if isAuth() && isNotBanned();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── Reports (UGC moderation queue) ─────────────────────
    // Apple App Review 1.2 requires a functional reporting mechanism.
    // Reporters can create; only admins can read/update/delete.
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Promotions ─────────────────────────────────────────
    match /promotions/{promoId} {
      allow read: if isAuth();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.businessId == request.auth.uid;
      allow update: if isOwner(resource.data.businessId) || isAdmin()
        || (isAuth() && changedOnly(['views','saves','currentRedemptions']));
      allow delete: if isOwner(resource.data.businessId) || isAdmin();
    }

    // ── Trips (top-level, in addition to users/{uid}/trips) ─
    match /trips/{tripId} {
      allow read: if isAuth();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── Audit Log ─────────────────────────────────────────────
    // Written by admin actions; only admins may read or write.
    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // audit records are immutable
    }

    // ── GDPR Requests ─────────────────────────────────────────
    // Users may create requests for their own data; admins process them.
    match /gdpr_requests/{requestId} {
      allow read: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Stories (24h ephemeral, like Instagram) ─────────────────
    match /stories/{storyId} {
      allow read: if isAuth();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── App Config (version check, feature flags) ─────────────
    match /config/{docId} {
      allow read: if true; // public — version check must work pre-auth
      allow write: if isAdmin();
    }
  }
}
